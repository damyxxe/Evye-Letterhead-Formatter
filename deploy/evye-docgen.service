[Unit]
Description=Evye Document Generator API
After=network.target

[Service]
Type=simple
User=evyeadmin
Group=evyeadmin
WorkingDirectory=/opt/evye-docgen
ExecStart=/opt/evye-docgen/.venv/bin/uvicorn api:app --host 127.0.0.1 --port 8089 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
